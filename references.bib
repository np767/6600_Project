
@article{liu_application_2025,
	title = {Application of artificial intelligence {CNN} model in emotional recognition of instrumental music},
	volume = {15},
	copyright = {2025 The Author(s)},
	issn = {2045-2322},
	url = {https://www.nature.com/articles/s41598-025-33623-1},
	doi = {10.1038/s41598-025-33623-1},
	abstract = {To enhance the accuracy and expressiveness of emotional recognition in instrumental music, this study proposes a multi-layer music emotion recognition model. The model integrates Convolutional Neural Network (CNN), Bidirectional Gated Recurrent Unit (BiGRU), and Attention Mechanism, aiming to accurately capture complex emotional information in audio. First, the CNN is used to extract local emotional features of the audio. Then, the BiGRU is employed to model the contextual information of time series, strengthening the temporal continuity of emotional expression. Finally, the attention mechanism is introduced to dynamically focus on key emotional segments. To achieve multi-scale feature fusion, the model combines low-level audio features and high-level semantic features through weighted summation during the feature extraction stage. The experimental section is validated using three music emotion datasets, including two publicly available datasets Instrument Recognition in Musical Audio Signals (IRMAS) and Multitrack Dataset for Musical Audio (MedleyDB), as well as a large-scale dataset Database for Emotional Analysis of Music (DEAM), to comprehensively evaluate the performance, generalization ability, and robustness of the model. These datasets cover a large number of multi-category instrumental audio samples. The model is evaluated on three continuous emotional dimensions: Valence, Arousal, and Dominance. The experimental results show that the proposed model achieves Pearson correlation coefficients of 0.871, 0.832, and 0.784, respectively, which are better than those of the comparative models. In terms of Mean Squared Error (MSE), the values are 0.0187, 0.0208, and 0.0243, respectively, indicating higher prediction accuracy. In conclusion, the proposed fusion deep neural network model significantly improves the accuracy and generalization ability of emotional recognition in instrumental music. This study provides an effective method and practical inspiration for emotional modeling in complex musical environments.},
	language = {en},
	number = {1},
	urldate = {2026-04-23},
	journal = {Scientific Reports},
	publisher = {Nature Publishing Group},
	author = {Liu, Yang},
	month = dec,
	year = {2025},
	keywords = {Engineering, Mathematics and computing, Neuroscience, Psychology},
	pages = {45155},
	file = {Full Text PDF:C\:\\Users\\arige\\Zotero\\storage\\QTTDBS6U\\Liu - 2025 - Application of artificial intelligence CNN model in emotional recognition of instrumental music.pdf:application/pdf},
}

@inproceedings{pranolo_classification_2025,
	title = {Classification of {Music} {Genres} based on {Machine} {Learning} {SVM} and {CNN}},
	url = {https://ieeexplore.ieee.org/document/11035544},
	doi = {10.1109/ICPCSN65854.2025.11035544},
	abstract = {This study aims to compare the performance of two classification methods—Support Vector Machine (SVM) and Convolutional Neural Network (CNN)—in identifying music genres based on audio data from the GTZAN dataset. Data in a 30-second audio file is converted into a numerical and visual representation (Mel Spectrogram) for each model. The evaluation used precision, recall, and f1-score metrics and was supported by a confusion matrix. Results showed that SVM had higher accuracy (75\%) than CNN (71.5\%), with more stable performance in most genres. CNN showed superiority in certain genres, such as classical and hip-hop, but experienced a decline in accuracy in genres such as disco and rock. This analysis confirms that the selection of classification models should consider the characteristics of data and genres and open up opportunities for hybrid approaches or the use of more complex architectures in music classification.},
	urldate = {2026-04-23},
	booktitle = {2025 5th {International} {Conference} on {Pervasive} {Computing} and {Social} {Networking} ({ICPCSN})},
	publisher = {Institute of Electrical and Electronics Engineers},
	author = {Pranolo, Andri and Sularso, Sularso and Anwar, Nuril and Utama, Agung Bella Putra and Wibawa, Aji Prasetya and Rachman, Rafi Aulia},
	month = may,
	year = {2025},
	keywords = {Accuracy, Adaptation models, Analytical models, CNN, Convolutional neural networks, Data models, GTZAN dataset, music genre, Spectrogram, Support vector machines, SVM, Training data, Vectors, Visualization},
	pages = {1667--1670},
	file = {Snapshot:C\:\\Users\\arige\\Zotero\\storage\\I6WL638U\\11035544.html:text/html},
}

